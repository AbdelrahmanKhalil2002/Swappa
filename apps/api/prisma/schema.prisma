generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Catalog Enums ────────────────────────────────────────────────────────────

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum HeelType {
  STILETTO
  BLOCK
  WEDGE
  KITTEN
  CONE
  FLAT
}

enum HeelMaterial {
  METAL
  WOOD
  ACRYLIC
  RUBBER
}

// ─── Admin RBAC Enums ─────────────────────────────────────────────────────────

enum AdminModule {
  DASHBOARD
  CATALOG
  MEDIA
  INVENTORY
  RAW_MATERIALS
  MANUFACTURING
  QUALITY_CONTROL
  PROCUREMENT
  ORDERS
  RETURNS
  SHIPPING
  CRM
  SUPPORT
  REVIEWS
  PROMOTIONS
  ACCOUNTING
  HR
  NOTIFICATIONS
  ANALYTICS
  AUDIT_LOGS
  INTEGRATIONS
  SETTINGS
}

enum AdminAction {
  READ
  WRITE
  DELETE
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  permissions RolePermission[]
  adminUsers  AdminUser[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("roles")
}

model RolePermission {
  id     String      @id @default(cuid())
  roleId String
  module AdminModule
  action AdminAction
  role   Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action])
  @@map("role_permissions")
}

model AdminUser {
  id              String              @id @default(cuid())
  email           String              @unique
  password        String?
  firstName       String?
  lastName        String?
  isActive        Boolean             @default(true)
  inviteToken     String?
  inviteExpiresAt DateTime?
  resetToken      String?
  resetExpiresAt  DateTime?
  roleId          String
  role            Role                @relation(fields: [roleId], references: [id])
  refreshTokens   AdminRefreshToken[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("admin_users")
}

model AdminRefreshToken {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@map("admin_refresh_tokens")
}

model Customer {
  id              String                 @id @default(cuid())
  email           String                 @unique
  password        String
  firstName       String
  lastName        String
  emailVerified   Boolean                @default(false)
  verifyToken     String?
  verifyExpiresAt DateTime?
  resetToken      String?
  resetExpiresAt  DateTime?
  refreshTokens   CustomerRefreshToken[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@map("customers")
}

model CustomerRefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@map("customer_refresh_tokens")
}

model FactoryWorker {
  id            String                @id @default(cuid())
  name          String
  pin           String
  isActive      Boolean               @default(true)
  refreshTokens FactoryRefreshToken[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@map("factory_workers")
}

model FactoryRefreshToken {
  id              String        @id @default(cuid())
  tokenHash       String        @unique
  factoryWorkerId String
  factoryWorker   FactoryWorker @relation(fields: [factoryWorkerId], references: [id], onDelete: Cascade)
  expiresAt       DateTime
  createdAt       DateTime      @default(now())

  @@map("factory_refresh_tokens")
}

// ─── Catalog ──────────────────────────────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  baseShoes   BaseShoe[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("categories")
}

model BaseShoe {
  id             String              @id @default(cuid())
  name           String
  slug           String              @unique
  description    String?
  status         ProductStatus       @default(DRAFT)
  categoryId     String?
  category       Category?           @relation(fields: [categoryId], references: [id])
  basePrice      Decimal             @db.Decimal(10, 2)
  seoTitle       String?
  seoDescription String?
  media          ProductMedia[]
  variants       ProductVariant[]
  compatibility  HeelCompatibility[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@map("base_shoes")
}

model HeelStyle {
  id             String              @id @default(cuid())
  name           String
  slug           String              @unique
  description    String?
  status         ProductStatus       @default(DRAFT)
  type           HeelType
  heightCm       Float
  material       HeelMaterial?
  addedPrice     Decimal             @default(0) @db.Decimal(10, 2)
  seoTitle       String?
  seoDescription String?
  media          ProductMedia[]
  compatibility  HeelCompatibility[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@map("heel_styles")
}

model HeelCompatibility {
  id           String    @id @default(cuid())
  baseShoeId   String
  heelStyleId  String
  isCompatible Boolean   @default(true)
  notes        String?
  baseShoe     BaseShoe  @relation(fields: [baseShoeId], references: [id], onDelete: Cascade)
  heelStyle    HeelStyle @relation(fields: [heelStyleId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([baseShoeId, heelStyleId])
  @@map("heel_compatibility")
}

model ProductVariant {
  id         String   @id @default(cuid())
  baseShoeId String
  baseShoe   BaseShoe @relation(fields: [baseShoeId], references: [id], onDelete: Cascade)
  size       String
  color      String
  material   String?
  sku        String   @unique
  stock      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("product_variants")
}

model ProductMedia {
  id          String     @id @default(cuid())
  url         String
  key         String
  alt         String?
  position    Int        @default(0)
  baseShoeId  String?
  heelStyleId String?
  baseShoe    BaseShoe?  @relation(fields: [baseShoeId], references: [id], onDelete: Cascade)
  heelStyle   HeelStyle? @relation(fields: [heelStyleId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())

  @@map("product_media")
}
