generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Catalog Enums ────────────────────────────────────────────────────────────

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum HeelType {
  STILETTO
  BLOCK
  WEDGE
  KITTEN
  CONE
  FLAT
}

enum HeelMaterial {
  METAL
  WOOD
  ACRYLIC
  RUBBER
}

enum MediaType {
  GALLERY
  FRAME_360
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum CouponType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
}

// ─── Admin RBAC Enums ─────────────────────────────────────────────────────────

enum AdminModule {
  DASHBOARD
  CATALOG
  MEDIA
  INVENTORY
  RAW_MATERIALS
  MANUFACTURING
  QUALITY_CONTROL
  PROCUREMENT
  ORDERS
  RETURNS
  SHIPPING
  CRM
  SUPPORT
  REVIEWS
  PROMOTIONS
  ACCOUNTING
  HR
  NOTIFICATIONS
  ANALYTICS
  AUDIT_LOGS
  INTEGRATIONS
  SETTINGS
}

enum AdminAction {
  READ
  WRITE
  DELETE
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  permissions RolePermission[]
  adminUsers  AdminUser[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("roles")
}

model RolePermission {
  id     String      @id @default(cuid())
  roleId String
  module AdminModule
  action AdminAction
  role   Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action])
  @@map("role_permissions")
}

model AdminUser {
  id              String              @id @default(cuid())
  email           String              @unique
  password        String?
  firstName       String?
  lastName        String?
  isActive        Boolean             @default(true)
  inviteToken     String?
  inviteExpiresAt DateTime?
  resetToken      String?
  resetExpiresAt  DateTime?
  roleId          String
  role            Role                @relation(fields: [roleId], references: [id])
  refreshTokens   AdminRefreshToken[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("admin_users")
}

model AdminRefreshToken {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@map("admin_refresh_tokens")
}

model Customer {
  id              String                 @id @default(cuid())
  email           String                 @unique
  password        String
  firstName       String
  lastName        String
  emailVerified   Boolean                @default(false)
  verifyToken     String?
  verifyExpiresAt DateTime?
  resetToken      String?
  resetExpiresAt  DateTime?
  footLengthMm    Int?
  footWidthMm     Int?
  refreshTokens   CustomerRefreshToken[]
  orders          Order[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@map("customers")
}

model CustomerRefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@map("customer_refresh_tokens")
}

model FactoryWorker {
  id            String                @id @default(cuid())
  name          String
  pin           String
  isActive      Boolean               @default(true)
  refreshTokens FactoryRefreshToken[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@map("factory_workers")
}

model FactoryRefreshToken {
  id              String        @id @default(cuid())
  tokenHash       String        @unique
  factoryWorkerId String
  factoryWorker   FactoryWorker @relation(fields: [factoryWorkerId], references: [id], onDelete: Cascade)
  expiresAt       DateTime
  createdAt       DateTime      @default(now())

  @@map("factory_refresh_tokens")
}

// ─── Catalog ──────────────────────────────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  baseShoes   BaseShoe[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("categories")
}

model BaseShoe {
  id             String              @id @default(cuid())
  name           String
  slug           String              @unique
  description    String?
  status         ProductStatus       @default(DRAFT)
  categoryId     String?
  category       Category?           @relation(fields: [categoryId], references: [id])
  basePrice      Decimal             @db.Decimal(10, 2)
  seoTitle       String?
  seoDescription String?
  media          ProductMedia[]
  variants       ProductVariant[]
  compatibility  HeelCompatibility[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@map("base_shoes")
}

model HeelStyle {
  id             String              @id @default(cuid())
  name           String
  slug           String              @unique
  description    String?
  status         ProductStatus       @default(DRAFT)
  type           HeelType
  heightCm       Float
  material       HeelMaterial?
  addedPrice     Decimal             @default(0) @db.Decimal(10, 2)
  layerImageUrl  String?
  seoTitle       String?
  seoDescription String?
  media          ProductMedia[]
  compatibility  HeelCompatibility[]
  orderItems     OrderItem[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@map("heel_styles")
}

model HeelCompatibility {
  id           String    @id @default(cuid())
  baseShoeId   String
  heelStyleId  String
  isCompatible Boolean   @default(true)
  notes        String?
  baseShoe     BaseShoe  @relation(fields: [baseShoeId], references: [id], onDelete: Cascade)
  heelStyle    HeelStyle @relation(fields: [heelStyleId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([baseShoeId, heelStyleId])
  @@map("heel_compatibility")
}

model ProductVariant {
  id         String      @id @default(cuid())
  baseShoeId String
  baseShoe   BaseShoe    @relation(fields: [baseShoeId], references: [id], onDelete: Cascade)
  size       String
  color      String
  material   String?
  sku        String      @unique
  stock      Int         @default(0)
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("product_variants")
}

model ProductMedia {
  id          String     @id @default(cuid())
  url         String
  key         String
  alt         String?
  position    Int        @default(0)
  type        MediaType  @default(GALLERY)
  baseShoeId  String?
  heelStyleId String?
  baseShoe    BaseShoe?  @relation(fields: [baseShoeId], references: [id], onDelete: Cascade)
  heelStyle   HeelStyle? @relation(fields: [heelStyleId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())

  @@map("product_media")
}

// ─── Orders & Checkout ────────────────────────────────────────────────────────

model Coupon {
  id             String     @id @default(cuid())
  code           String     @unique
  type           CouponType
  value          Decimal    @db.Decimal(10, 2)
  minOrderAmount Decimal?   @db.Decimal(10, 2)
  maxUses        Int?
  usedCount      Int        @default(0)
  expiresAt      DateTime?
  isActive       Boolean    @default(true)
  orders         Order[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("coupons")
}

model Order {
  id                    String        @id @default(cuid())
  orderNumber           String        @unique
  customerId            String?
  customer              Customer?     @relation(fields: [customerId], references: [id])
  email                 String
  firstName             String
  lastName              String
  phone                 String
  addressLine1          String
  addressLine2          String?
  city                  String
  governorate           String
  status                OrderStatus   @default(PENDING)
  paymentStatus         PaymentStatus @default(PENDING)
  stripePaymentIntentId String?       @unique
  subtotal              Decimal       @db.Decimal(10, 2)
  shippingCost          Decimal       @default(0) @db.Decimal(10, 2)
  discountAmount        Decimal       @default(0) @db.Decimal(10, 2)
  total                 Decimal       @db.Decimal(10, 2)
  couponId              String?
  coupon                Coupon?       @relation(fields: [couponId], references: [id])
  shippingMethod        String        @default("standard")
  notes                 String?
  items                 OrderItem[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@map("orders")
}

model OrderItem {
  id            String         @id @default(cuid())
  orderId       String
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id])
  heelStyleId   String?
  heelStyle     HeelStyle?     @relation(fields: [heelStyleId], references: [id])
  quantity      Int
  unitPrice     Decimal        @db.Decimal(10, 2)
  heelPrice     Decimal        @default(0) @db.Decimal(10, 2)
  lineTotal     Decimal        @db.Decimal(10, 2)
  snapshotName  String
  snapshotSku   String
  createdAt     DateTime       @default(now())

  @@map("order_items")
}
