# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/swappa

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret
JWT_ADMIN_SECRET=change-me-admin-jwt-secret
JWT_FACTORY_SECRET=change-me-factory-jwt-secret
JWT_REFRESH_SECRET=change-me-in-production-refresh
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SUPERADMIN_EMAIL=admin@swappa.com
SUPERADMIN_PASSWORD=Admin@123456!

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@swappa.com

# ─── Cloudflare R2 (Media Storage) ───────────────────────────────────────────
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=swappa-media
R2_PUBLIC_URL=https://media.swappa.com

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=...
NEXT_PUBLIC_SENTRY_DSN=...

# ─── Shipping ────────────────────────────────────────────────────────────────
EASYPOST_API_KEY=...

# ─── App URLs ────────────────────────────────────────────────────────────────
STOREFRONT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
FACTORY_URL=http://localhost:3002
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Node ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
